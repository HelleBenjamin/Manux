SYSCALL_COUNT     EQU KERNEL_WORKSPACE+8
KERNEL_FLAGS      EQU KERNEL_WORKSPACE+10
PROC_COUNT        EQU KERNEL_WORKSPACE+12
TEMP_SP           EQU KERNEL_WORKSPACE+14

; Temporal registers
TMP_REG1          EQU KERNEL_WORKSPACE+16
